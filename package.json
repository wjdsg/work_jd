{
  "name": "core-matrix",
  "version": "1.0.1",
  "description": "Log management desktop app",
  "author": "mjw",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:compile": "tsc -p tsconfig.electron.json && node scripts/prepare-electron-main.cjs",
    "electron:build": "npm run build && npm run electron:compile && electron-builder --win nsis",
    "electron:preview": "npm run build && npm run electron:compile && cross-env NODE_ENV=production electron .",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "build": {
    "appId": "com.mjw.core-matrix",
    "productName": "Core Matrix",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowElevation": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "date-fns": "^3.4.0",
    "idb": "^8.0.0",
    "nodemailer": "^8.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^17.5.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.1.4",
    "vitest": "^1.3.1",
    "wait-on": "^9.0.5"
  }
}
